# ── Candidate ─────────────────────────────────────────────────────────────────
CANDIDATE_NAME=Your Full Name
CANDIDATE_EMAIL=your@email.com
CANDIDATE_PORTFOLIO=yourportfolio.com
CANDIDATE_LINKEDIN=linkedin.com/in/yourhandle

# ── LLM Backend ───────────────────────────────────────────────────────────────
LLM_MODE=claude                        # claude | codex | openclaw
CLAUDE_BIN=/usr/local/bin/claude       # path to claude CLI
CODEX_BIN=/usr/local/bin/codex         # path to codex CLI
CODEX_MODEL=gpt-5.3-codex
OPENCLAW_AGENT=coding

# ── Notifications ─────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# ── Notion Integration ────────────────────────────────────────────────────────
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LinkedIn ──────────────────────────────────────────────────────────────────
LINKEDIN_EMAIL=your@email.com
