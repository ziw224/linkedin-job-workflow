# Copy this file to .env and fill in your values.
# .env is gitignored and stays on your machine only.

# ── Discord ────────────────────────────────────────────────────────────────────
# Webhook URL for daily job report notifications.
# Create one at: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# ── Resume paths (optional) ───────────────────────────────────────────────────
# Point to your personal resume files OUTSIDE the repo — keeps your private info
# out of git. If not set, falls back to resume/base_resume.html (the template).
#
# RESUME_HTML_PATH=~/Documents/resumes/my_resume.html
# RESUME_AI_HTML_PATH=~/Documents/resumes/my_resume_ai.html
