# Copy this file to .env and fill in your values.
# .env is gitignored and stays on your machine only.

# ── Discord ────────────────────────────────────────────────────────────────────
# Option A: Webhook URL (single-user, simpler setup)
# Create one at: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Option B: Bot token (multi-user, routes each user's notifications to their own channel)
# Notifications go to users.notify_channel_id from the DB if set, else fall back to webhook.
# DISCORD_BOT_TOKEN=your_bot_token_here

# ── MySQL database (optional — enables multi-user support + run history) ───────
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=job_workflow
# Setup: mysql -u root -p < schema.sql

# ── Resume paths (optional) ───────────────────────────────────────────────────
# Point to your personal resume files OUTSIDE the repo — keeps your private info
# out of git. If not set, falls back to resume/base_resume.html (the template).
#
# RESUME_HTML_PATH=~/Documents/resumes/my_resume.html
# RESUME_AI_HTML_PATH=~/Documents/resumes/my_resume_ai.html
