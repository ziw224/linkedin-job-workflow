# Copy this to .env and fill in your values

# Discord webhook for daily job notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Model backend for generation (manual switch, no auto-fallback)
# claude   -> use local Claude CLI
# openclaw -> use `openclaw agent --local` with configured model/fallback stack
LLM_MODE=claude
OPENCLAW_AGENT=coding
