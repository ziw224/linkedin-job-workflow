# Copy this to .env and fill in your values

# Discord webhook for daily job notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Model backend for generation (manual switch, no auto-fallback)
# claude   -> use local Claude CLI
# codex    -> use local Codex CLI (`codex exec`)
# openclaw -> use `openclaw agent --local` with configured model stack
LLM_MODE=claude
CODEX_MODEL=gpt-5.3-codex
OPENCLAW_AGENT=coding
